{
  "name": "akshay-bankar-mern-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "MERN stack portfolio for Akshay Bankar.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev -w client",
    "server": "npm run dev -w server",
    "build": "npm run build -w client",
    "start": "npm start -w server",
    "install-all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
